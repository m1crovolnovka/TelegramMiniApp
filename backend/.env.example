# Copy to .env for local docker run: docker run --env-file .env ...
SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:postgresql://localhost:5432/casino
DB_USER=casino
DB_PASSWORD=change-me

TELEGRAM_BOT_TOKEN=
CASINO_JWT_SECRET=change-me-use-long-random-secret-at-least-32-chars

# Optional — default in Docker image is /app/data/storage
# CASINO_STORAGE_LOCAL_DIR=/app/data/storage

# Optional — override CORS (comma-separated). Default list in application.yml
# CASINO_CORS_ALLOWED_ORIGINS=https://telegram-mini-app-4njn.vercel.app,http://localhost:5173
